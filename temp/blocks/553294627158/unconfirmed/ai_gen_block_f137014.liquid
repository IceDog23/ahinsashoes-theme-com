{% doc %}
  @prompt
    generate custom liquid block for quick HTML customization
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-html-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-custom-html-content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    line-height: {{ block.settings.line_height }};
    text-align: {{ block.settings.text_align }};
  }

  .ai-custom-html-content-{{ ai_gen_id }} h1,
  .ai-custom-html-content-{{ ai_gen_id }} h2,
  .ai-custom-html-content-{{ ai_gen_id }} h3,
  .ai-custom-html-content-{{ ai_gen_id }} h4,
  .ai-custom-html-content-{{ ai_gen_id }} h5,
  .ai-custom-html-content-{{ ai_gen_id }} h6 {
    color: {{ block.settings.heading_color }};
    margin-top: 0;
    margin-bottom: 16px;
  }

  .ai-custom-html-content-{{ ai_gen_id }} p {
    margin-top: 0;
    margin-bottom: 16px;
  }

  .ai-custom-html-content-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
  }

  .ai-custom-html-content-{{ ai_gen_id }} a:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-custom-html-content-{{ ai_gen_id }} img {
    max-width: 100%;
    height: auto;
  }

  .ai-custom-html-content-{{ ai_gen_id }} ul,
  .ai-custom-html-content-{{ ai_gen_id }} ol {
    margin-top: 0;
    margin-bottom: 16px;
    padding-left: 24px;
  }

  .ai-custom-html-content-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  .ai-custom-html-content-{{ ai_gen_id }} blockquote {
    margin: 0 0 16px;
    padding-left: 20px;
    border-left: 4px solid {{ block.settings.border_color }};
    font-style: italic;
  }

  .ai-custom-html-content-{{ ai_gen_id }} table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 16px;
  }

  .ai-custom-html-content-{{ ai_gen_id }} th,
  .ai-custom-html-content-{{ ai_gen_id }} td {
    padding: 12px;
    border: 1px solid {{ block.settings.border_color }};
    text-align: left;
  }

  .ai-custom-html-content-{{ ai_gen_id }} th {
    background-color: {{ block.settings.table_header_bg }};
    font-weight: 600;
  }

  .ai-custom-html-empty-state-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    color: #999;
    font-style: italic;
    background-color: #f9f9f9;
    border: 2px dashed #ddd;
    border-radius: {{ block.settings.border_radius }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-custom-html-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px;
    }

    .ai-custom-html-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-custom-html-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.custom_html != blank %}
    <div class="ai-custom-html-content-{{ ai_gen_id }}">
      {{ block.settings.custom_html }}
    </div>
  {% else %}
    <div class="ai-custom-html-empty-state-{{ ai_gen_id }}">
      Add your custom HTML in the block settings
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Custom HTML",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "HTML content"
    },
    {
      "type": "html",
      "id": "custom_html",
      "label": "HTML code"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding horizontal",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Headings",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Links",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Links hover",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Borders",
      "default": "#e8e8e1"
    },
    {
      "type": "color",
      "id": "table_header_bg",
      "label": "Table header background",
      "default": "#f9f9f9"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "Line height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.5
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Custom HTML"
    }
  ]
}
{% endschema %}