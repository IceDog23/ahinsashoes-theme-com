{% doc %}
  @prompt
    Create a premium two-column hero banner with countdown timer, discount badge, CTA buttons, and bottom feature bar, styled in neutral beige minimal design, fully editable in Shopify theme editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-banner-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    position: relative;
  }

  .ai-hero-banner__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: {{ block.settings.min_height }}px;
    position: relative;
  }

  .ai-hero-banner__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: {{ block.settings.content_padding }}px;
    position: relative;
  }

  .ai-hero-banner__badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 8px 16px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
    margin-bottom: 20px;
    width: fit-content;
    letter-spacing: 0.5px;
  }

  .ai-hero-banner__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px 0;
    line-height: 1.2;
    font-weight: 700;
  }

  .ai-hero-banner__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 24px 0;
    line-height: 1.6;
  }

  .ai-hero-banner__countdown-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    margin-bottom: 32px;
  }

  .ai-hero-banner__countdown-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    background-color: {{ block.settings.countdown_bg_color }};
    padding: 16px 20px;
    border-radius: {{ block.settings.countdown_border_radius }}px;
    min-width: 70px;
  }

  .ai-hero-banner__countdown-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.countdown_number_size }}px;
    font-weight: 700;
    color: {{ block.settings.countdown_number_color }};
    line-height: 1;
    margin-bottom: 4px;
  }

  .ai-hero-banner__countdown-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.countdown_label_size }}px;
    color: {{ block.settings.countdown_label_color }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-hero-banner__buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .ai-hero-banner__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    border: 2px solid transparent;
    cursor: pointer;
  }

  .ai-hero-banner__button--primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_color }};
    border-color: {{ block.settings.primary_button_bg }};
  }

  .ai-hero-banner__button--primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_hover_bg }};
    border-color: {{ block.settings.primary_button_hover_bg }};
  }

  .ai-hero-banner__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_button_bg }};
    color: {{ block.settings.secondary_button_color }};
    border-color: {{ block.settings.secondary_button_border }};
  }

  .ai-hero-banner__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_hover_bg }};
    border-color: {{ block.settings.secondary_button_hover_border }};
  }

  .ai-hero-banner__image-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-hero-banner__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
  }

  .ai-hero-banner__image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-banner__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.placeholder_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-banner__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
    opacity: 0.3;
  }

  .ai-hero-banner__features-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.features_columns }}, 1fr);
    gap: 24px;
    padding: {{ block.settings.features_padding }}px;
    background-color: {{ block.settings.features_bg_color }};
    border-top: 1px solid {{ block.settings.features_border_color }};
  }

  .ai-hero-banner__feature-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-hero-banner__feature-icon-{{ ai_gen_id }} {
    width: {{ block.settings.feature_icon_size }}px;
    height: {{ block.settings.feature_icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ block.settings.feature_icon_color }};
  }

  .ai-hero-banner__feature-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-hero-banner__feature-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_text_size }}px;
    color: {{ block.settings.feature_text_color }};
    line-height: 1.4;
  }

  @media screen and (max-width: 768px) {
    .ai-hero-banner__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .ai-hero-banner__content-{{ ai_gen_id }} {
      padding: 32px 24px;
      order: 2;
    }

    .ai-hero-banner__image-{{ ai_gen_id }} {
      min-height: 300px;
      order: 1;
    }

    .ai-hero-banner__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-hero-banner__subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }

    .ai-hero-banner__countdown-{{ ai_gen_id }} {
      gap: 12px;
    }

    .ai-hero-banner__countdown-item-{{ ai_gen_id }} {
      padding: 12px 16px;
      min-width: 60px;
    }

    .ai-hero-banner__countdown-number-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.countdown_number_size }}px * 0.8);
    }

    .ai-hero-banner__buttons-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-hero-banner__button-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-hero-banner__features-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 24px;
    }
  }
{% endstyle %}

<hero-banner-{{ ai_gen_id }} class="ai-hero-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-banner__container-{{ ai_gen_id }}">
    <div class="ai-hero-banner__content-{{ ai_gen_id }}">
      {% if block.settings.show_badge and block.settings.badge_text != blank %}
        <div class="ai-hero-banner__badge-{{ ai_gen_id }}">
          {{ block.settings.badge_text }}
        </div>
      {% endif %}

      {% if block.settings.heading != blank %}
        <h2 class="ai-hero-banner__heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <div class="ai-hero-banner__subheading-{{ ai_gen_id }}">
          {{ block.settings.subheading }}
        </div>
      {% endif %}

      {% if block.settings.show_countdown %}
        <div class="ai-hero-banner__countdown-{{ ai_gen_id }}" data-countdown-end="{{ block.settings.countdown_end_date }}">
          <div class="ai-hero-banner__countdown-item-{{ ai_gen_id }}">
            <div class="ai-hero-banner__countdown-number-{{ ai_gen_id }}" data-countdown-days>00</div>
            <div class="ai-hero-banner__countdown-label-{{ ai_gen_id }}">Days</div>
          </div>
          <div class="ai-hero-banner__countdown-item-{{ ai_gen_id }}">
            <div class="ai-hero-banner__countdown-number-{{ ai_gen_id }}" data-countdown-hours>00</div>
            <div class="ai-hero-banner__countdown-label-{{ ai_gen_id }}">Hours</div>
          </div>
          <div class="ai-hero-banner__countdown-item-{{ ai_gen_id }}">
            <div class="ai-hero-banner__countdown-number-{{ ai_gen_id }}" data-countdown-minutes>00</div>
            <div class="ai-hero-banner__countdown-label-{{ ai_gen_id }}">Mins</div>
          </div>
          <div class="ai-hero-banner__countdown-item-{{ ai_gen_id }}">
            <div class="ai-hero-banner__countdown-number-{{ ai_gen_id }}" data-countdown-seconds>00</div>
            <div class="ai-hero-banner__countdown-label-{{ ai_gen_id }}">Secs</div>
          </div>
        </div>
      {% endif %}

      <div class="ai-hero-banner__buttons-{{ ai_gen_id }}">
        {% if block.settings.primary_button_label != blank %}
          <a href="{{ block.settings.primary_button_link }}" class="ai-hero-banner__button-{{ ai_gen_id }} ai-hero-banner__button--primary-{{ ai_gen_id }}">
            {{ block.settings.primary_button_label }}
          </a>
        {% endif %}

        {% if block.settings.secondary_button_label != blank %}
          <a href="{{ block.settings.secondary_button_link }}" class="ai-hero-banner__button-{{ ai_gen_id }} ai-hero-banner__button--secondary-{{ ai_gen_id }}">
            {{ block.settings.secondary_button_label }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="ai-hero-banner__image-{{ ai_gen_id }}">
      <div class="ai-hero-banner__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1200 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
          >
        {% else %}
          <div class="ai-hero-banner__image-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  {% if block.settings.show_features %}
    <div class="ai-hero-banner__features-{{ ai_gen_id }}">
      {% if block.settings.feature_1_text != blank %}
        <div class="ai-hero-banner__feature-{{ ai_gen_id }}">
          <div class="ai-hero-banner__feature-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6L9 17l-5-5"/>
            </svg>
          </div>
          <div class="ai-hero-banner__feature-text-{{ ai_gen_id }}">
            {{ block.settings.feature_1_text }}
          </div>
        </div>
      {% endif %}

      {% if block.settings.feature_2_text != blank %}
        <div class="ai-hero-banner__feature-{{ ai_gen_id }}">
          <div class="ai-hero-banner__feature-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div class="ai-hero-banner__feature-text-{{ ai_gen_id }}">
            {{ block.settings.feature_2_text }}
          </div>
        </div>
      {% endif %}

      {% if block.settings.feature_3_text != blank %}
        <div class="ai-hero-banner__feature-{{ ai_gen_id }}">
          <div class="ai-hero-banner__feature-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div class="ai-hero-banner__feature-text-{{ ai_gen_id }}">
            {{ block.settings.feature_3_text }}
          </div>
        </div>
      {% endif %}

      {% if block.settings.feature_4_text != blank %}
        <div class="ai-hero-banner__feature-{{ ai_gen_id }}">
          <div class="ai-hero-banner__feature-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="3" width="15" height="13"/>
              <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
              <circle cx="5.5" cy="18.5" r="2.5"/>
              <circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
          </div>
          <div class="ai-hero-banner__feature-text-{{ ai_gen_id }}">
            {{ block.settings.feature_4_text }}
          </div>
        </div>
      {% endif %}
    </div>
  {% endif %}
</hero-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.countdownElement = this.querySelector('[data-countdown-end]');
        this.countdownInterval = null;
      }

      connectedCallback() {
        if (this.countdownElement) {
          this.initCountdown();
        }
      }

      disconnectedCallback() {
        if (this.countdownInterval) {
          clearInterval(this.countdownInterval);
        }
      }

      initCountdown() {
        const endDateStr = this.countdownElement.getAttribute('data-countdown-end');
        if (!endDateStr) return;

        const endDate = new Date(endDateStr).getTime();

        const updateCountdown = () => {
          const now = new Date().getTime();
          const distance = endDate - now;

          if (distance < 0) {
            if (this.countdownInterval) {
              clearInterval(this.countdownInterval);
            }
            this.setCountdownValues(0, 0, 0, 0);
            return;
          }

          const days = Math.floor(distance / (1000 * 60 * 60 * 24));
          const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);

          this.setCountdownValues(days, hours, minutes, seconds);
        };

        updateCountdown();
        this.countdownInterval = setInterval(updateCountdown, 1000);
      }

      setCountdownValues(days, hours, minutes, seconds) {
        const daysEl = this.querySelector('[data-countdown-days]');
        const hoursEl = this.querySelector('[data-countdown-hours]');
        const minutesEl = this.querySelector('[data-countdown-minutes]');
        const secondsEl = this.querySelector('[data-countdown-seconds]');

        if (daysEl) daysEl.textContent = String(days).padStart(2, '0');
        if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
        if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
        if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');
      }
    }

    customElements.define('hero-banner-{{ ai_gen_id }}', HeroBanner{{ ai_gen_id }});
  })();
</script>

